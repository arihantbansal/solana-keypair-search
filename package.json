{
  "name": "solana-keypair-search",
  "version": "0.1.0",
  "description": "TUI to scan your filesystem for Solana keypairs and inspect their balances, deployed programs, and reclaimable buffers.",
  "type": "module",
  "module": "src/cli.tsx",
  "bin": {
    "solana-keypair-search": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "build": "bun build src/cli.tsx --outdir dist --target bun",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@opentui/core": "0.1.97",
    "@opentui/react": "0.1.97",
    "@solana-program/loader-v3": "0.3.0",
    "@solana/kit": "6.7.0",
    "react": "19.2.4",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/react": "19.2.14",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "typescript": "6.0.2"
  }
}
